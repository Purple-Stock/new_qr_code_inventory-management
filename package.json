{
  "name": "purple-stock-next",
  "private": true,
  "type": "module",
  "scripts": {
    "db:migrate": "tsx ./src/db/migrate.ts",
    "db:rollback": "tsx ./src/db/rollback.ts",
    "db:new": "node ./scripts/new-migration.mjs",
    "user:promote-super-admin": "node ./scripts/promote-super-admin.mjs",
    "db:seed": "tsx ./src/db/seed.ts",
    "dev": "next dev --webpack",
    "dev:local-default": "NEXT_DIST_DIR=.next-dev-3001 PORT=3001 npm run dev",
    "dev:local-prod": "node ./scripts/dev-with-env.mjs --env-file=.env.prod.local --port=3101",
    "check:architecture": "node ./scripts/check-architecture.mjs",
    "check:test-policy": "node ./scripts/check-test-policy.mjs",
    "lint:architecture": "eslint src/lib/services src/app/api --max-warnings=0",
    "test:architecture": "vitest run src/__tests__/scripts/check-architecture.test.ts",
    "verify:architecture": "npm run check:architecture && npm run check:test-policy && npm run lint:architecture && npm run test:architecture",
    "precommit:required": "node ./scripts/pre-commit.mjs",
    "prepush:required": "npm run verify:architecture && npm run build",
    "prepush:full": "npm run verify:architecture && npm test && npm run build",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:uninstall": "git config --unset core.hooksPath",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@libsql/client": "^0.17.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.2",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.6",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.9",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^1.0.0-rc.2",
    "esbuild": "^0.28.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "dompurify": "^3.4.5",
    "postcss": "^8.5.14"
  }
}
